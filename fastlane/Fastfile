require "base64"

# Absolute path to the Flutter project root (one level above fastlane/)
ROOT = File.expand_path("..", __dir__)

default_platform(:ios)

# ─── iOS ──────────────────────────────────────────────────────────────────────

platform :ios do
  desc "Capture App Store screenshots for all devices and locales, then frame them"
  lane :screenshots do
    sh("cd #{ROOT} && flutter pub get")
    sh("cd #{ROOT} && dart run build_runner build --delete-conflicting-outputs")

    # Kill any stale simulator processes left over from a previous (crashed) run.
    # Each booted iOS 26 simulator consumes ~2–3 GB RAM on the 14 GB macOS runner.
    sh("xcrun simctl shutdown all 2>/dev/null || true", log: false)
    sleep(3)

    # ── Build ONCE — reused for every device × locale combination ─────────────
    # IMPORTANT: must build with --target pointing at the integration test entry
    # point, not lib/main.dart. flutter drive --use-application-binary installs
    # the binary as-is; if it was built from lib/main.dart the app never calls
    # IntegrationTestWidgetsFlutterBinding.ensureInitialized() and the driver
    # hangs waiting for a VM service extension that never appears.
    app_path = "#{ROOT}/build/ios/iphonesimulator/Runner.app"
    sh("cd #{ROOT} && flutter build ios --debug --simulator --target=integration_test/screenshot_test.dart --dart-define=SCREENSHOT_MODE=true")

    all_devices = [
      { sim: "iPhone 17 Pro Max",     dir: "iPhone_17_Pro_Max", type: "iphone" },
      { sim: "iPad Pro 13-inch (M5)", dir: "iPad_Pro_13",       type: "ipad"   },
    ]
    # SCREENSHOT_DEVICE_TYPE=iphone runs only iPhones (CI iphone job).
    # SCREENSHOT_DEVICE_TYPE=ipad   runs only iPads   (CI ipad job).
    # Unset: run all devices (local use).
    device_filter = ENV["SCREENSHOT_DEVICE_TYPE"]
    devices = device_filter \
      ? all_devices.select { |d| d[:type] == device_filter } \
      : all_devices
    locales = [
      { locale: "en-US", lang: "en", region: "en_US" },
      { locale: "de-DE", lang: "de", region: "de_DE" },
    ]

    devices.each do |device|
      sim_id = sh(
        "xcrun simctl list devices available | grep '#{device[:sim]}' | grep -oE '[A-F0-9-]{36}' | head -1",
        log: false
      ).strip

      if sim_id.empty?
        UI.important("Simulator '#{device[:sim]}' not found — skipping.")
        next
      end

      begin
        locales.each do |loc|
          UI.message("📸  #{device[:sim]} · #{loc[:locale]}")

          # Boot a FRESH simulator for every locale run.
          #
          # Keeping the simulator alive across locale switches causes
          # SpringBoard to become unresponsive on the iPad Pro 13 after a
          # prolonged integration-test session (flutter drive stays connected
          # for ~2 min per run). The fresh boot also reclaims the ~2-3 GB
          # RAM the simulator holds, preventing OOM on the 14 GB macOS runner
          # after several sequential runs.
          #
          # bootstatus -b blocks until SpringBoard is fully ready.
          sh("xcrun simctl boot #{sim_id} 2>/dev/null || true", log: false)
          sh("xcrun simctl bootstatus #{sim_id} -b", log: false)
          # Simulator.app must be open so the springboard renders correctly.
          sh("open -a Simulator --args -CurrentDeviceUDID #{sim_id}", log: false)
          sleep(5)

          # Write locale while the simulator is running — simctl spawn
          # requires a booted device. The app reads these keys at launch.
          sh("xcrun simctl spawn #{sim_id} defaults write -g AppleLanguages -array '#{loc[:lang]}'", log: false)
          sh("xcrun simctl spawn #{sim_id} defaults write -g AppleLocale '#{loc[:region]}'", log: false)

          # Install the pre-built integration-test binary.
          sh("xcrun simctl install #{sim_id} '#{app_path}'", log: false)

          out_dir = "#{ROOT}/fastlane/screenshots/#{loc[:locale]}/#{device[:dir]}"
          sh("mkdir -p #{out_dir}")

          # --use-application-binary skips the Xcode build (~110 s) entirely.
          sh(
            "cd #{ROOT} && SCREENSHOT_OUT_DIR=#{out_dir} flutter drive " \
            "--driver=test_driver/integration_test.dart " \
            "--target=integration_test/screenshot_test.dart " \
            "--use-application-binary='#{app_path}' " \
            "-d #{sim_id}"
          )

          # Shutdown immediately after each locale run to free RAM before
          # the next boot. The ensure block is a safety net if we raise here.
          sh("xcrun simctl shutdown #{sim_id} 2>/dev/null || true", log: false)
          sleep(3)
        end
      ensure
        # Safety net: guarantee shutdown even if a locale run raised.
        sh("xcrun simctl shutdown #{sim_id} 2>/dev/null || true", log: false)
      end
    end

    # Apply device frames + marketing text from title.strings
    frame_screenshots(path: "#{ROOT}/fastlane/screenshots")

    # App Store Connect rejects PNGs that contain an alpha channel.
    # frameit outputs RGBA even when a background colour is set in Framefile.json,
    # so flatten every framed screenshot onto its own background pixels here.
    sh("find '#{ROOT}/fastlane/screenshots' -name '*.png' -exec mogrify -flatten {} \\;")

  desc "Build and deploy to TestFlight"
  lane :deploy do
    # Flutter dependencies & code generation
    sh("cd #{ROOT} && flutter pub get")
    sh("cd #{ROOT} && dart run build_runner build --delete-conflicting-outputs")

    # Create a temporary CI keychain
    setup_ci

    # Install distribution certificate
    cert_path = "/tmp/dist.p12"
    File.binwrite(cert_path, Base64.strict_decode64(ENV.fetch("IOS_DISTRIBUTION_CERT_BASE64")))
    import_certificate(
      certificate_path: cert_path,
      certificate_password: ENV.fetch("IOS_DISTRIBUTION_CERT_PASSWORD"),
      keychain_name: ENV.fetch("MATCH_KEYCHAIN_NAME", "fastlane_tmp_keychain"),
      keychain_password: ENV.fetch("MATCH_KEYCHAIN_PASSWORD", "")
    )

    # Install provisioning profile and extract its UUID
    profile_path = "/tmp/dist.mobileprovision"
    File.binwrite(profile_path, Base64.strict_decode64(ENV.fetch("IOS_PROVISIONING_PROFILE_BASE64")))
    install_provisioning_profile(path: profile_path)

    # PlistBuddy cannot read from stdin reliably — decode to a temp file first
    sh("security cms -D -i #{profile_path} > /tmp/decoded_profile.plist", log: false)
    profile_uuid = sh(
      "/usr/libexec/PlistBuddy -c 'Print :UUID' /tmp/decoded_profile.plist",
      log: false
    ).strip
    UI.message("Using provisioning profile: #{profile_uuid}")

    # Build Flutter iOS artifacts without code signing
    # (Xcode will apply signing during the archive step below)
    sh("cd #{ROOT} && flutter build ios --release --no-codesign")

    # Set signing settings only on the Runner target.
    # PROVISIONING_PROFILE_SPECIFIER must NOT be passed via xcargs because
    # xcargs applies to every target — SPM package targets (frameworks) do
    # not support provisioning profiles and will error if one is specified.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "#{ROOT}/ios/Runner.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      profile_uuid: profile_uuid,
      targets: ["Runner"]
    )

    # Archive and export a signed IPA.
    # xcargs only carries settings that are safe to apply globally:
    #   DEVELOPMENT_TEAM  — required by Xcode 15+ for every SPM package target
    #   CODE_SIGN_STYLE   — puts SPM targets in manual mode so they don't
    #                       conflict with the profile set on Runner above
    build_app(
      workspace: "#{ROOT}/ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      codesigning_identity: "Apple Distribution",
      xcargs: "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')} CODE_SIGN_STYLE=Manual",
      export_method: "app-store",
      export_options: {
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        signingStyle: "manual",
        provisioningProfiles: { "com.ITWebService.SilverTimer" => profile_uuid },
        uploadSymbols: false,
        uploadBitcode: false
      },
      output_directory: "#{ROOT}/build/ios/ipa",
      output_name: "SilverTimer.ipa"
    )

    # Upload to TestFlight
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APPSTORE_API_KEY_ID"),
      issuer_id: ENV.fetch("APPSTORE_ISSUER_ID"),
      key_content: ENV.fetch("APPSTORE_API_KEY_BASE64"),
      is_key_content_base64: true,
      duration: 1200
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: "#{ROOT}/build/ios/ipa/SilverTimer.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end

# ─── Android ──────────────────────────────────────────────────────────────────

platform :android do
  desc "Capture Play Store screenshots for phone and tablet, then frame them"
  lane :screenshots do
    sh("cd #{ROOT} && flutter pub get")
    sh("cd #{ROOT} && dart run build_runner build --delete-conflicting-outputs")

    in_ci = ENV.key?("CI")

    # In CI each job handles ONE AVD (set via SCREENSHOT_AVD env var) because
    # reactivecircus/android-emulator-runner only manages one emulator per job
    # and ubuntu-latest has only 7 GB RAM — not enough for two concurrent instances.
    # Locally, all devices run in sequence.
    all_devices = [
      { avd: "Pixel_10_Pro", dir: "Phone" },
    ]
    avd_filter   = ENV["SCREENSHOT_AVD"]
    active_devices = avd_filter \
      ? all_devices.select { |d| d[:avd] == avd_filter } \
      : all_devices

    locales = [
      { locale: "en-US", lang: "en-US" },
      { locale: "de-DE", lang: "de-DE" },
    ]

    # ── Build ONCE — reused for every device × locale combination ─────────────
    # Must use --target=integration_test/screenshot_test.dart so the binary
    # contains IntegrationTestWidgetsFlutterBinding — same reason as iOS.
    apk_path = "#{ROOT}/build/app/outputs/flutter-apk/app-debug.apk"
    sh("cd #{ROOT} && flutter build apk --debug --target=integration_test/screenshot_test.dart --dart-define=SCREENSHOT_MODE=true")

    active_devices.each do |device|
      unless in_ci
        # Locally: start a fresh emulator for this device.
        sh("$ANDROID_HOME/emulator/emulator -avd #{device[:avd]} -no-audio -no-window &", log: false)
      end

      # Wait for the emulator to be fully booted (CI emulator is pre-started by
      # reactivecircus/android-emulator-runner; local emulator just launched above).
      sh("adb wait-for-device shell 'while [[ -z $(getprop sys.boot_completed) ]]; do sleep 1; done'", log: false)
      sleep(3) # allow system services to settle after boot

      package = "com.it_web_service.silvertimer"

      locales.each do |loc|
        UI.message("📸  #{device[:avd]} · #{loc[:locale]}")

        # Switch locale using the Android 13+ per-app locale API — no root required.
        # `cmd locale set-app-locales` writes the locale for this package into
        # PackageManager; Flutter reads it on next launch via the system Configuration.
        # `am force-stop` ensures the app process is dead so flutter drive gets a
        # cold start with the new locale already in effect.
        sh("adb shell cmd locale set-app-locales #{package} --locales #{loc[:lang]}", log: false)
        sh("adb shell am force-stop #{package}", log: false)
        sleep(2)

        out_dir = "#{ROOT}/fastlane/screenshots/#{loc[:locale]}/#{device[:dir]}"
        sh("mkdir -p #{out_dir}")

        # --use-application-binary skips the Gradle build (~315 s) entirely.
        sh(
          "cd #{ROOT} && SCREENSHOT_OUT_DIR=#{out_dir} flutter drive " \
          "--driver=test_driver/integration_test.dart " \
          "--target=integration_test/screenshot_test.dart " \
          "--use-application-binary='#{apk_path}' " \
          "-d emulator-5554"
        )
      end

      unless in_ci
        # Locally: kill and wait for the emulator to fully stop before
        # starting the next device, to avoid two concurrent instances.
        sh("adb emu kill", log: false)
        sleep(5)
      end
    end

    # NOTE: frame_screenshots is intentionally omitted for Android.
    # frameit only recognises exact real-device resolutions and the Pixel 10 Pro
    # emulator resolution is not in the frameit catalogue.
    # Google Play Store does not require framed screenshots — raw
    # screenshots are uploaded and reviewed as-is.
  end

  desc "Build and deploy to Play Store internal track"
  lane :deploy do
    # Flutter dependencies & code generation
    sh("cd #{ROOT} && flutter pub get")
    sh("cd #{ROOT} && dart run build_runner build --delete-conflicting-outputs")

    # Write signing config (key.properties + decoded keystore)
    File.write("#{ROOT}/android/key.properties", [
      "storePassword=#{ENV.fetch('KEYSTORE_PASSWORD')}",
      "keyPassword=#{ENV.fetch('KEY_PASSWORD')}",
      "keyAlias=#{ENV.fetch('KEY_ALIAS')}",
      "storeFile=../upload-keystore.jks"
    ].join("\n"))
    File.binwrite(
      "#{ROOT}/android/upload-keystore.jks",
      Base64.strict_decode64(ENV.fetch("KEYSTORE_BASE64"))
    )

    # Build release AAB
    sh("cd #{ROOT} && flutter build appbundle --release")

    # Upload to Play Store — fastlane supply gives detailed error output
    upload_to_play_store(
      package_name: "com.it_web_service.silvertimer",
      aab: "#{ROOT}/build/app/outputs/bundle/release/app-release.aab",
      track: "internal",
      json_key_data: ENV.fetch("PLAY_STORE_JSON_KEY"),
      release_status: "completed"
    )
  end
end
